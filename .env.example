APP_NAME=Veloquent
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_REALTIME_DB=1
REDIS_REALTIME_PREFIX=
REDIS_REALTIME_READ_TIMEOUT=-1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Veloquent
VELO_API_PREFIX=api
VELO_ADMIN_PREFIX=
VELO_COLLECTION_PREFIX=_velo_
VELO_DEFAULT_AUTH_COLLECTION=users
VELO_TENANTS_DB_PREFIX=velo_tenant_

VELO_RECORDS_PER_PAGE_MAX=500
VELO_RECORDS_EXPAND_MAX=10
VELO_COLLECTION_CACHE_TTL=0

VELO_REALTIME_BUS=redis
VELO_REALTIME_MODE=persistent
VELO_REALTIME_TTL=55
VELO_REALTIME_SUBSCRIPTION_TTL=120

VELO_OTP_LENGTH=6
VELO_OTP_TTL=15
VELO_OTP_CLEANUP_GRACE=60

VELO_OAUTH_STATE_TTL=300
VELO_OAUTH_EXCHANGE_TTL=90

VELO_LOGS_SLOW_QUERY_THRESHOLD=1000
VELO_LOGS_IP_ENABLED=true

VELO_IS_DEMO=false
VELO_DEMO_EMAIL=demo@velophp.com
VELO_DEMO_PASSWORD=demo@123123

# ---------------------------------------------------------------------------
# Broadcast / WebSocket
#
# To switch providers, change BROADCAST_CONNECTION and fill in that
# provider's vars below. The Blade template reads the active connection
# from Laravel's broadcasting config and injects it into the page — the
# frontend picks it up automatically with no other changes needed.
#
# Supported: reverb | pusher | ably
# ---------------------------------------------------------------------------
VITE_BROADCAST_CONNECTION="${BROADCAST_CONNECTION}"

# ---------------------------------------------------------------------------
# Provider credentials
# ---------------------------------------------------------------------------

# -- Reverb --
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# -- Pusher (or Pusher-compatible: Soketi, Piesocket, etc.) --
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1
PUSHER_PORT=443
PUSHER_SCHEME=https
# PUSHER_HOST=   <-- only for self-hosted; omit for official Pusher

# -- Ably --
# ABLY_KEY=
